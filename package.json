{
  "name": "hockey-nomination-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "prisma db push --accept-data-loss && next start --hostname 0.0.0.0",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts",
    "inject:league": "npx ts-node --project scripts/tsconfig.json scripts/inject-league-json.ts",
    "sort:candidates": "npx ts-node --project scripts/tsconfig.json scripts/sort-ms-candidates.ts",
    "stats:extraliga": "node scripts/extraliga-coverage.mjs",
    "promo:capture-squad": "node scripts/capture-promo-squad.cjs",
    "og:pad-top": "node scripts/pad-og-top.mjs",
    "email:broadcast": "node scripts/resend-broadcast.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-pg": "^6.9.0",
    "@prisma/client": "^6.9.0",
    "canvas-confetti": "^1.9.4",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.8.0",
    "lz-string": "^1.5.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "pg": "^8.20.0",
    "prisma": "^6.9.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/lz-string": "^1.3.34",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.51.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
