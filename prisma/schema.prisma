// Prisma schema for MS 2026 Hockey Nomination MVP

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id        String   @id @default(cuid())
  name      String
  position  String // G, D, F (skupina pro limity)
  role      String? // RW, LW, C, RB, LB (detailní pozice)
  club      String
  league    String? // NHL, AHL, …; NULL u starých řádků → dopočet v API z klubu
  /// Číslo na dresu (repre / klub z JSON). Není unikátní — stejné číslo může mít víc hráčů (repre vs. klub).
  jerseyNumber Int?
  createdAt DateTime @default(now())

  @@map("players")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  nominations   Nomination[] @relation("NominationOwner")
  /// Jedna nominace na uživatele započítaná do soutěže (odeslání do soutěže).
  contestEntryNominationId String? @unique
  contestEntryNomination   Nomination? @relation("ContestEntry", fields: [contestEntryNominationId], references: [id], onDelete: SetNull)

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Nomination {
  id                String   @id @default(cuid())
  userId            String?
  selectedPlayerIds String[]
  captainId         String?
  lineupStructure   Json?
  createdAt         DateTime @default(now())
  /// U konceptů 0; u řádku „odeslání do soutěže“ koeficient v okamžiku odeslání (0 / 10 / 25 / 40).
  timeBonusPercent  Int      @default(0)
  /// Vlastní název nominace (volitelné), max. cca 80 znaků.
  title             String?
  /// Krátká veřejná URL část (např. /v/moje-sestava). Jedinečné napříč tabulkou.
  slug              String?  @unique

  user               User? @relation("NominationOwner", fields: [userId], references: [id], onDelete: SetNull)
  contestEntryForUser User? @relation("ContestEntry")

  @@map("nominations")
}

/// Krátký odkaz pro hosta (/l/{code}) — bez účtu, přepíše se při změně sestavy novým kódem.
model ShareLink {
  code              String   @id @db.VarChar(12)
  captainId         String?
  lineupStructure   Json
  title             String?
  createdAt         DateTime @default(now())

  @@map("share_links")
}

/// Jedna řádka: oficiální soupiska pro vyhodnocení soutěže (admin editor).
model OfficialLineup {
  id              String   @id
  lineupStructure Json
  captainId       String?
  updatedAt       DateTime @updatedAt

  @@map("official_lineup")
}
