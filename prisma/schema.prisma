// Prisma schema for MS 2026 Hockey Nomination MVP

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id        String   @id @default(cuid())
  name      String
  position  String // G, D, F (skupina pro limity)
  role      String? // RW, LW, C, RB, LB (detailní pozice)
  club      String
  league    String? // NHL, AHL, …; NULL u starých řádků → dopočet v API z klubu
  /// Číslo na dresu (repre / klub z JSON). Není unikátní — stejné číslo může mít víc hráčů (repre vs. klub).
  jerseyNumber Int?
  createdAt DateTime @default(now())

  @@map("players")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  /// Veřejné jméno v žebříčku (volitelné). Když není, zobrazí se anonymní "Hráč #XXXX".
  leaderboardNickname String?
  accounts      Account[]
  sessions      Session[]
  nominations   Nomination[] @relation("NominationOwner")
  pickemEntry   PickemEntry?
  matchShareLinks MatchShareLink[]
  msFantasyLineups MsFantasyLineup[]
  /// Jedna nominace na uživatele započítaná do soutěže (odeslání do soutěže).
  contestEntryNominationId String? @unique
  contestEntryNomination   Nomination? @relation("ContestEntry", fields: [contestEntryNominationId], references: [id], onDelete: SetNull)
  communityPosts         CommunityPost[]
  communityComments      CommunityComment[]
  communityPostLikes     CommunityPostLike[]

  @@map("users")
}

model PickemEntry {
  id        String   @id @default(cuid())
  userId    String   @unique
  /** Uložené tipy (celý payload Pick’em). */
  payload   Json
  /// Jednorázové odeslání Pick’emu do soutěže — po nastavení už uživatel nemůže měnit uložený payload ani znovu soutěžně odeslat.
  contestSubmittedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pickem_entries")
}

model EmailBroadcastSend {
  id         String   @id @default(cuid())
  campaignId String
  email      String
  status     String   @default("sending") // sending | sent | failed
  resendId   String?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([campaignId, email])
  @@index([campaignId])
  @@map("email_broadcast_sends")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Nomination {
  id                String   @id @default(cuid())
  userId            String?
  selectedPlayerIds String[]
  captainId         String?
  lineupStructure   Json?
  createdAt         DateTime @default(now())
  /// U konceptů 0; u řádku „odeslání do soutěže“ koeficient v okamžiku odeslání (0 / 10 / 25 / 40).
  timeBonusPercent  Int      @default(0)
  /// Vlastní název nominace (volitelné), max. cca 80 znaků.
  title             String?
  /// Krátká veřejná URL část (např. /v/moje-sestava). Jedinečné napříč tabulkou.
  slug              String?  @unique

  user               User? @relation("NominationOwner", fields: [userId], references: [id], onDelete: SetNull)
  contestEntryForUser User? @relation("ContestEntry")
  communityAttachments CommunityPostAttachment[]

  @@map("nominations")
}

/// Hostovské sdílení: `code` = vnitřní ID pro PATCH; `slug` = veřejná URL /v/{slug} z názvu nominace.
model ShareLink {
  code              String   @id @db.VarChar(12)
  slug              String?  @unique
  captainId         String?
  lineupStructure   Json
  title             String?
  createdAt         DateTime @default(now())

  @@map("share_links")
}

/// Jedna řádka: oficiální soupiska pro vyhodnocení soutěže (admin editor).
model OfficialLineup {
  id              String   @id
  lineupStructure Json
  captainId       String?
  updatedAt       DateTime @updatedAt

  @@map("official_lineup")
}

/// Zápasy (Beijir hockey games) — oficiální sestava + hodnocení hráčů.
model Match {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  /// "beijir" | "ms2026" — filtr pro /zapasy
  category  String   @default("beijir")
  /// Volitelné kódy týmů pro hezký list (CZE, SWE, FIN, USA…)
  homeCode  String?
  awayCode  String?
  opponent  String?
  startsAt  DateTime?
  venue     String?
  published Boolean  @default(false)
  /// Pokud true, hodnocení (1–10) je otevřené pro uživatele bez ohledu na čas zápasu (admin tlačítko „Spustit hodnocení“).
  ratingsOpen Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  officialLineup MatchOfficialLineup?
  ratings        MatchRating[]
  ratingExports  MatchRatingShareLink[]

  @@map("matches")
}

model MatchOfficialLineup {
  matchId           String  @id
  lineupStructure   Json
  captainId         String?
  defenseCount      Int     @default(8) // 8 / 7 / 6
  allowExtraForward Boolean @default(false) // 13. útočník
  updatedAt         DateTime @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("match_official_lineups")
}

/// Jedno hodnocení hráče v konkrétním zápase od jednoho hodnotitele.
/// raterKey = "u:{userId}" nebo "a:{anonCookie}".
/// `rating` je Float (1.0–10.0 s krokem 0.1), aby šly oznámkovat i poloviny / desetiny.
model MatchRating {
  id        String   @id @default(cuid())
  matchId   String
  playerId  String
  rating    Float
  raterKey  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId, raterKey])
  @@index([matchId, playerId])
  @@map("match_ratings")
}

/// Hostovské sdílení fanouškovské sestavy na zápas (nezávislé na zápase).
model MatchShareLink {
  code              String   @id @db.VarChar(12)
  slug              String?  @unique
  userId            String?
  captainId         String?
  lineupStructure   Json
  title             String?
  defenseCount      Int      @default(8)
  allowExtraForward Boolean  @default(false)
  createdAt         DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("match_share_links")
}

/// Export / sdílení snapshotu hodnocení zápasu (veřejná URL /h/{slug}).
model MatchRatingShareLink {
  code      String   @id @db.VarChar(12)
  slug      String   @unique
  matchId   String
  title     String?
  snapshot  Json
  createdAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@map("match_rating_share_links")
}

/// Hráč ve fantasy poolu MS — import z Excelu: ID→`code`, jméno, pozice O/Ú/B→G/D/F, tým, kategorie→`tier`, číslo dresu.
model MsFantasyRosterPlayer {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  team         String
  jerseyNumber Int?
  /// G | D | F — v databázi vždy tyto hodnoty; z Excelu (O / Ú / B) při importu přemapuj přes `normalizeMsFantasyPosition`.
  position     String
  /// Kategorie z Excelu (úroveň hráče A–E) — plat dle `msFantasyConfig`.
  tier         String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([position])
  @@index([active])
  @@map("ms_fantasy_roster_players")
}

/// Jeden uzamykatelný hrací den (deadline = lockAt u prvního zápasu dne, viz `matches`).
model MsFantasyGameDay {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  lockAt    DateTime
  /// Zápasy daného kalendářního dne MS (časy v ISO UTC). Pořadí podle `startAt`.
  matches   Json     @default("[]")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineups           MsFantasyLineup[]
  playerDayStats    MsFantasyPlayerDayStat[]
  lineupDayResults  MsFantasyLineupDayResult[]

  @@index([lockAt])
  @@map("ms_fantasy_game_days")
}

/// Statistiky hráče z poolu za jeden fantasy den (admin vyplní → body dle pravidel).
model MsFantasyPlayerDayStat {
  id             String   @id @default(cuid())
  gameDayId      String
  rosterPlayerId String
  goals          Int      @default(0)
  assists        Int      @default(0)
  plusMinus      Int      @default(0)
  wins           Int      @default(0)
  goalsAgainst   Int      @default(0)
  shutouts       Int      @default(0)
  /// Vypočtené fantasy body za den (cache po uložení / vyhodnocení).
  fantasyPoints  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  gameDay MsFantasyGameDay @relation(fields: [gameDayId], references: [id], onDelete: Cascade)

  @@unique([gameDayId, rosterPlayerId])
  @@index([gameDayId])
  @@map("ms_fantasy_player_day_stats")
}

/// Výsledek vyhodnocení jedné odevzdané sestavy za den.
model MsFantasyLineupDayResult {
  id        String   @id @default(cuid())
  lineupId  String   @unique
  gameDayId String
  userId    String
  points    Int
  /// Pořadí slotů: jméno, pozice, body, statistiky.
  breakdown Json     @default("[]")
  scoredAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineup  MsFantasyLineup  @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  gameDay MsFantasyGameDay @relation(fields: [gameDayId], references: [id], onDelete: Cascade)

  @@index([gameDayId, points])
  @@index([userId])
  @@map("ms_fantasy_lineup_day_results")
}

/// Odevzdaná sestava uživatele na konkrétní den (6× id z poolu, pořadí = sloty).
model MsFantasyLineup {
  id          String   @id @default(cuid())
  userId      String
  gameDayId   String
  pickIds     String[]
  /// Tier u každého slotu v pořadí `pickIds` — snímek v okamžiku odevzdání (změna tieru v rosteru nemění historické sestavy).
  pickTiers    String[] @default([])
  /// Plat v kreditech u každého slotu v pořadí `pickIds` — snímek při odevzdání; součet = `salarySpent`.
  pickSalaries Int[]    @default([])
  salarySpent Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// RESTRICT: smazání `MsFantasyGameDay` s existujícími lineupy v DB selže — odevzdané sestavy se nikdy nesmažou kaskádou.
  gameDay   MsFantasyGameDay          @relation(fields: [gameDayId], references: [id], onDelete: Restrict)
  dayResult MsFantasyLineupDayResult?

  @@unique([userId, gameDayId])
  @@index([gameDayId])
  @@map("ms_fantasy_lineups")
}

// ——— Komunita / fórum (preview přes admin) ———

enum CommunityPostCategory {
  LINEUP_NOMINATION
  FANTASY
  GENERAL
  Q_AND_A
  MEMES
  OFF_TOPIC
}

enum CommunityPostStatus {
  PUBLISHED
  HIDDEN
  DELETED
}

enum CommunityAttachmentKind {
  NOMINATION
  MATCH_LINEUP
  FANTASY_LINEUP
  INLINE_SNAPSHOT
}

model CommunityPost {
  id            String                @id @default(cuid())
  slug          String                @unique
  authorId      String
  category      CommunityPostCategory
  title         String                @db.VarChar(120)
  bodyMd        String                @db.Text
  status        CommunityPostStatus   @default(PUBLISHED)
  pinnedAt      DateTime?
  likeCount     Int                   @default(0)
  commentCount  Int                   @default(0)
  score         Int                   @default(0)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  deletedAt     DateTime?

  author      User                      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  attachments CommunityPostAttachment[]
  tags        CommunityPostTag[]
  comments    CommunityComment[]
  likes       CommunityPostLike[]

  @@index([status, createdAt(sort: Desc)])
  @@index([status, score(sort: Desc)])
  @@index([status, commentCount(sort: Desc)])
  @@index([category, createdAt(sort: Desc)])
  @@map("community_posts")
}

model CommunityPostAttachment {
  id           String                  @id @default(cuid())
  postId       String
  sortOrder    Int                     @default(0)
  kind         CommunityAttachmentKind
  nominationId String?
  snapshot     Json
  createdAt    DateTime                @default(now())

  post       CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  nomination Nomination?   @relation(fields: [nominationId], references: [id], onDelete: SetNull)

  @@index([postId, sortOrder])
  @@map("community_post_attachments")
}

model CommunityTag {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  useCount  Int      @default(0)
  createdAt DateTime @default(now())

  posts CommunityPostTag[]

  @@map("community_tags")
}

model CommunityPostTag {
  postId String
  tagId  String

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  CommunityTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("community_post_tags")
}

model CommunityComment {
  id        String              @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?
  bodyMd    String              @db.Text
  likeCount Int                 @default(0)
  status    CommunityPostStatus @default(PUBLISHED)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  post    CommunityPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  CommunityComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies CommunityComment[] @relation("CommentThread")

  @@index([postId, createdAt])
  @@index([parentId])
  @@map("community_comments")
}

model CommunityPostLike {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@map("community_post_likes")
}
