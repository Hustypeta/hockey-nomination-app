// Prisma schema for MS 2026 Hockey Nomination MVP

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id        String   @id @default(cuid())
  name      String
  position  String   // G, D, F (skupina pro limity)
  role      String?  // RW, LW, C, RB, LB (detailní pozice)
  club      String
  league    String?  // NHL, AHL, …; NULL u starých řádků → dopočet v API z klubu
  createdAt DateTime @default(now())

  @@map("players")
}

model User {
  id         String       @id @default(cuid())
  email      String       @unique
  nominations Nomination[]

  @@map("users")
}

model Nomination {
  id                String   @id @default(cuid())
  userId            String? // volitelné – nominace bez účtu
  selectedPlayerIds String[]
  captainId         String?
  lineupStructure   Json?
  createdAt         DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("nominations")
}
