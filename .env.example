# PostgreSQL connection string (Railway, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Veřejná adresa (bez www) — stejná hodnota i pro Open Graph / sdílení
# NEXT_PUBLIC_SITE_URL="https://hokejlineup.cz"

# NextAuth (https://next-auth.js.org/configuration/options#secret)
# Na Railway povinné: NEXTAUTH_SECRET + NEXTAUTH_URL=https://hokejlineup.cz (kanonická adresa, bez www)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generuj-nahodny-retezec-napriklad-openssl-rand-base64-32"
# Volitelné alias pro stejnou hodnotu (některé nástroje nastavují AUTH_SECRET):
# AUTH_SECRET=""

# Google OAuth – Credentials v Google Cloud Console (OAuth consent + OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Veřejný kontakt ve zásadách ochrany osobních údajů (/ochrana-udaju); výchozí kontakt@hokejlineup.cz
# NEXT_PUBLIC_CONTACT_EMAIL=""

# Instagram profilu Lineup (ikony „Sledujte Lineup…“ v patičce — NE kanál Svět Hokeje, ten je v kódu fixně)
# NEXT_PUBLIC_INSTAGRAM_PAGE_URL="https://www.instagram.com/hokejlineup/"

# Fantasy MS: stránky /fantasy (při explicitním false je /fantasy 404). Pro soutěž na produkci nastav true.
NEXT_PUBLIC_MS_FANTASY_VISIBLE="true"

# Fantasy: odeslání sestavy = účast u hracího dne. Pro ostrý sběr soutěžních sestav nech true (výchozí při chybějícím env je zapnuto).
NEXT_PUBLIC_MS_FANTASY_SUBMISSION_ENABLED="true"

# Volitelně po `prisma migrate` + seed: vloží vzorové hrací dny a několik řádků poolu (Excel později přepíše).
# MS_FANTASY_SEED_SAMPLE="true"
