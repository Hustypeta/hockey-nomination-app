# Personalizovaný e-mail účastníkům soutěže (body + pořadí).
# Resend běží na Railway — lokálně nepotřebuješ RESEND_API_KEY, jen EMAIL_BROADCAST_SECRET na serveru.

$Secret = "c3f8e6a1f4b24d8c9a7e1b2c5d6f7a8091b2c3d4e5f60718293a4b5c6d7e8f90"   # stejné jako EMAIL_BROADCAST_SECRET na Railway
$Campaign = "contest-results-thanks-2026-05-v2"   # nová kampaň = nové odeslání (jinak se přeskočí už odeslané)
$Base = "https://hokejlineup.cz"

$Headers = @{
  "x-email-secret" = $Secret
  "Content-Type"   = "application/json"
}

# 1) Test — jeden účastník (musí mít odevzdanou nominaci do soutěže)
Invoke-RestMethod -Uri "$Base/api/admin/email/contest-results?mode=send&only=petr.hustak263@gmail.com&campaignId=test-contest-results-1" -Method Post -Headers $Headers -Body "{}"

# 2) Dry-run — všichni účastníci + body a pořadí
Invoke-RestMethod -Uri "$Base/api/admin/email/contest-results?mode=dry-run&limit=9999&offset=0" -Method Post -Headers $Headers -Body "{}"

# 3) Odeslání všem 33 (jedna vlna)
Invoke-RestMethod -Uri "$Base/api/admin/email/contest-results?campaignId=$Campaign&mode=send&limit=9999&offset=0" -Method Post -Headers $Headers -Body "{}"

# Volitelně ve vlnách:
# Invoke-RestMethod -Uri "$Base/api/admin/email/contest-results?campaignId=$Campaign&mode=send&limit=15&offset=0" -Method Post -Headers $Headers -Body "{}"
# Invoke-RestMethod -Uri "$Base/api/admin/email/contest-results?campaignId=$Campaign&mode=send&limit=18&offset=15" -Method Post -Headers $Headers -Body "{}"
