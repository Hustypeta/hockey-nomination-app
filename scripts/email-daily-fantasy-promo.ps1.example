# Daily Fantasy — registrovaní mimo nominační soutěž (bez contest entry).
# Resend běží na Railway — lokálně nepotřebuješ RESEND_API_KEY, jen EMAIL_BROADCAST_SECRET na serveru.

$Secret = "c3f8e6a1f4b24d8c9a7e1b2c5d6f7a8091b2c3d4e5f60718293a4b5c6d7e8f90"   # stejné jako EMAIL_BROADCAST_SECRET na Railway
$Campaign = "daily-fantasy-promo-2026-05-v1"
$Base = "https://hokejlineup.cz"

$Headers = @{
  "x-email-secret" = $Secret
  "Content-Type"   = "application/json"
}

# 1) Test — jeden e-mail (funguje i u účtu v nominační soutěži, když je only=)
Invoke-RestMethod -Uri "$Base/api/admin/email/daily-fantasy-promo?mode=send&only=petr.hustak263@gmail.com&campaignId=test-daily-fantasy-1" -Method Post -Headers $Headers -Body "{}"

# 2) Dry-run — kolik příjemců + seznam
Invoke-RestMethod -Uri "$Base/api/admin/email/daily-fantasy-promo?mode=dry-run&limit=9999" -Method Post -Headers $Headers -Body "{}"

# 3) Odeslání všem
Invoke-RestMethod -Uri "$Base/api/admin/email/daily-fantasy-promo?campaignId=$Campaign&mode=send&limit=9999" -Method Post -Headers $Headers -Body "{}"
